TENANT_DATABASE_BASE_URL=mysql://moon_user:change-me@127.0.0.1:3306/moonsconfig
# Must be a privileged provisioning-only MySQL account; never expose it to the API client.
TENANT_PROVISIONING_DATABASE_URL=mysql://root:change-root-password@127.0.0.1:3306/mysql
TENANT_DATABASE_CONNECTION_LIMIT=2
TENANT_CREDENTIAL_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
