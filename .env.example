IMAP_USER=
IMAP_PASS=
OSRM_BASE_URL=https://router.project-osrm.org
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Enterprise API (the legacy variables above remain supported)
NODE_ENV=development
PORT=4000
REDIS_URL=redis://127.0.0.1:6379
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=moonsconfig
JWT_AUDIENCE=moonsconfig-client
OPERATOR_JWT_SECRET=replace-with-a-different-32-character-secret
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_DAYS=30
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:5174,http://localhost:8080
COOKIE_SECURE=false
CUSTOMER_COOKIE_SAME_SITE=lax
SOCKET_IO_ENABLED=true
ARI_URL=http://127.0.0.1:8088
ARI_USERNAME=asterisk
ARI_PASSWORD=replace-with-your-ari-password
ARI_OUTBOUND_ENDPOINT=moon
ASTERISK_WSL_DISTRO=Ubuntu
CRON_ENABLED=true
LEGACY_SESSION_ENABLED=true
LEGACY_ROUTING_ENABLED=true
PUBLIC_REGISTRATION_ENABLED=false
LEGAL_APPROVAL_DATE=
PEN_TEST_APPROVED_AT=
BACKUP_RESTORE_VERIFIED_AT=
STATUS_PAGE_URL=
INCIDENT_CONTACT=
MYSQLDUMP_BINARY=mysqldump
MYSQL_BINARY=mysql
AUTONOMOUS_SUPPORT_CRON=*/15 * * * * *
MAYA_AUTOPILOT_CRON=0 */10 * * * *
MAYA_OPS_SWEEP_CRON=0 */15 * * * *
TRAVEL_AUTOMATION_CRON=*/30 * * * * *

# Maya defaults to read-only until the governed write path is deliberately enabled.
MAYA_ENABLED=true
MAYA_EXTERNAL_WRITES_ENABLED=false
MAYA_TOOL_ALLOWLIST=
MAYA_BRAIN_MODEL=gemini-2.5-flash

# Certified travel providers. Missing capabilities fail closed and create staff exceptions.
