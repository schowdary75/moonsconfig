}

model MayaActionProposal {
  id             String           @id @default(uuid()) @db.Char(36)
  conversationId String?          @map("conversation_id") @db.Char(36)
  actionType     String           @map("action_type") @db.VarChar(100)
  riskClass      MayaRiskClass    @map("risk_class")
  subjectType    String           @map("subject_type") @db.VarChar(50)
  subjectRef     String           @map("subject_ref") @db.VarChar(120)
  input          Json
  evidence       Json
  policyVersion  String           @map("policy_version") @db.VarChar(80)
  idempotencyKey String           @unique(map: "uq_maya_action_idempotency") @map("idempotency_key") @db.VarChar(160)
  status         MayaActionStatus @default(pending)
  requestedBy    String           @map("requested_by") @db.VarChar(120)
  approvedBy     Int?             @map("approved_by")
  approvalReason String?          @map("approval_reason") @db.VarChar(500)
  expiresAt      DateTime         @map("expires_at") @db.DateTime(0)
  reviewedAt     DateTime?        @map("reviewed_at") @db.DateTime(0)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamp(0)

  @@index([status, riskClass, createdAt], map: "idx_maya_action_queue")
  @@index([subjectType, subjectRef], map: "idx_maya_action_subject")
  @@map("maya_action_proposals")
}

model MayaActionExecution {
  id                  String              @id @default(uuid()) @db.Char(36)
  proposalId          String              @map("proposal_id") @db.Char(36)
  attempt             Int                 @default(1)
  status              MayaExecutionStatus
  externalReference   String?             @map("external_reference") @db.VarChar(160)
  result              Json?
  errorCode           String?             @map("error_code") @db.VarChar(80)
  errorMessage        String?             @map("error_message") @db.VarChar(600)
  rollbackInformation Json?               @map("rollback_information")
  startedAt           DateTime            @default(now()) @map("started_at") @db.DateTime(0)
  completedAt         DateTime?           @map("completed_at") @db.DateTime(0)

  @@unique([proposalId, attempt], map: "uq_maya_execution_attempt")
  @@map("maya_action_executions")
}

model DomainOutboxEvent {
  id             String            @id @default(uuid()) @db.Char(36)
  aggregateType  String            @map("aggregate_type") @db.VarChar(80)
  aggregateId    String            @map("aggregate_id") @db.VarChar(120)
  eventType      String            @map("event_type") @db.VarChar(100)
  payload        Json
  idempotencyKey String            @unique(map: "uq_outbox_idempotency") @map("idempotency_key") @db.VarChar(160)
  status         OutboxEventStatus @default(pending)
  attempts       Int               @default(0)
  availableAt    DateTime          @default(now()) @map("available_at") @db.DateTime(0)
  publishedAt    DateTime?         @map("published_at") @db.DateTime(0)
  lastError      String?           @map("last_error") @db.VarChar(600)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamp(0)

  @@index([status, availableAt], map: "idx_outbox_dispatch")
  @@map("domain_outbox_events")
}

model AutomationRun {
  id             String              @id @default(uuid()) @db.Char(36)
  automationKey  String              @map("automation_key") @db.VarChar(100)
  sourceEventId  String              @map("source_event_id") @db.Char(36)
  idempotencyKey String              @unique(map: "uq_automation_run_idempotency") @map("idempotency_key") @db.VarChar(160)
  status         AutomationRunStatus @default(pending)
  currentStep    Int                 @default(0) @map("current_step")
  context        Json
  attempts       Int                 @default(0)
  nextAttemptAt  DateTime?           @map("next_attempt_at") @db.DateTime(0)
  lastError      String?             @map("last_error") @db.VarChar(600)
  startedAt      DateTime?           @map("started_at") @db.DateTime(0)
  completedAt    DateTime?           @map("completed_at") @db.DateTime(0)
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([status, nextAttemptAt], map: "idx_automation_runs_dispatch")
  @@map("automation_runs")
}

model ProviderCapabilityHealth {
  id                  String                   @id @default(uuid()) @db.Char(36)
  capability          String                   @db.VarChar(80)
  provider            String                   @db.VarChar(80)
  status              ProviderCapabilityStatus
  checkedAt           DateTime                 @map("checked_at") @db.DateTime(0)
  lastSuccessAt       DateTime?                @map("last_success_at") @db.DateTime(0)
  consecutiveFailures Int                      @default(0) @map("consecutive_failures")
  details             Json?

  @@unique([capability, provider], map: "uq_provider_capability")
  @@map("provider_capability_health")
}

