generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model CrmUser {
  id                                        Int                @id @default(autoincrement())
  email                                     String             @unique(map: "email") @db.VarChar(255)
  passwordHash                              String             @map("password_hash") @db.VarChar(255)
  role                                      CrmUserRole        @default(viewer)
  name                                      String?            @db.VarChar(255)
  createdAt                                 DateTime           @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                                 DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  mobile                                    String?            @db.VarChar(50)
  badgeKey                                  String?            @default("passport_elite") @map("badge_key") @db.VarChar(80)
  assets                                    assets[]
  sessions                                  CrmAuthSession[]
  lead_followups                            lead_followups[]
  marketing_leads                           marketing_leads[]
  packages_packages_created_byTocrm_users   packages[]         @relation("packages_created_byTocrm_users")
  packages_packages_published_byTocrm_users packages[]         @relation("packages_published_byTocrm_users")
  packages_packages_updated_byTocrm_users   packages[]         @relation("packages_updated_byTocrm_users")
  quotes                                    quotes[]
  refreshTokens                             AuthRefreshToken[]
  roles                                     CrmUserRoleLink[]

  @@map("crm_users")
}

model CrmAuthSession {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @unique(map: "token_hash") @map("token_hash") @db.Char(64)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  expiresAt DateTime @map("expires_at") @db.DateTime(0)
  user      CrmUser  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "crm_auth_sessions_ibfk_1")

  @@index([userId], map: "user_id")
  @@map("crm_auth_sessions")
}

model CrmUserRoleLink {
  userId    Int                 @map("user_id")
  role      crm_user_roles_role
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamp(0)
  user      CrmUser             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "crm_user_roles_user_id_fkey")

  @@id([userId, role])
  @@index([role], map: "idx_crm_user_roles_role")
  @@map("crm_user_roles")
}

model CustomerUser {
  id             Int                @id @default(autoincrement())
  name           String             @db.VarChar(255)
  email          String             @unique(map: "email") @db.VarChar(255)
  passwordHash   String?            @map("password_hash") @db.VarChar(255)
  oauthProvider  String?            @map("oauth_provider") @db.VarChar(50)
  oauthId        String?            @map("oauth_id") @db.VarChar(255)
  points_balance Int?               @default(500)
  avatar_url     String?            @db.VarChar(255)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamp(0)
  buddy_id       Int?
  phone          String?            @unique(map: "phone") @db.VarChar(50)
  address        String?            @db.Text
  city           String?            @db.VarChar(120)
  state          String?            @db.VarChar(120)
  postal_code    String?            @db.VarChar(30)
  country        String?            @db.VarChar(120)
  is_guest       Boolean            @default(false)
  invoices       invoices[]
  refreshTokens  AuthRefreshToken[]
  devices        CustomerDevice[]

  @@index([buddy_id], map: "buddy_id")
  @@map("users")
}

model CustomerDevice {
  id         Int          @id @default(autoincrement())
  userId     Int          @map("user_id")
  token      String       @unique(map: "uq_customer_devices_token") @db.VarChar(512)
  platform   String       @db.VarChar(20)
  appVersion String?      @map("app_version") @db.VarChar(40)
  lastSeenAt DateTime     @default(now()) @map("last_seen_at") @db.Timestamp(0)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  user       CustomerUser @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "customer_devices_user_id_fkey")

  @@index([userId], map: "idx_customer_devices_user")
  @@index([platform], map: "idx_customer_devices_platform")
  @@map("customer_devices")
}

