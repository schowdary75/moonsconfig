{
  "name": "@moonsconfig/server",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "predev": "npm run check:prisma-engine",
    "dev": "tsx watch src/server.ts",
    "preworker:dev": "npm run check:prisma-engine",
    "worker:dev": "tsx watch src/workers/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prestart": "npm run check:prisma-engine",
    "start": "node dist/server.js",
    "preworker": "npm run check:prisma-engine",
    "worker": "node dist/workers/index.js",
    "lint": "eslint src prisma --max-warnings=0",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate && node scripts/prisma-platform.mjs generate",
    "prisma:validate": "prisma validate && node scripts/prisma-platform.mjs validate",
    "check:runtime-sql": "node scripts/check-runtime-sql.mjs",
    "check:prisma-engine": "node scripts/check-prisma-client-engine.mjs",
    "check:route-security": "node scripts/check-route-security.mjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:deploy:platform": "node scripts/prisma-platform.mjs migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "ops:create": "tsx scripts/create-platform-operator.ts",
    "ops:catalog-seed": "tsx scripts/seed-plan-catalog.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1093.0",
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/client-secrets-manager": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "@google/generative-ai": "^0.24.1",
    "@per_moeller/asterisk-ari": "^1.0.29",
    "@prisma/client": "^7.9.0",
    "@workos-inc/node": "^10.8.0",
    "archiver": "^8.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.80.12",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.6.0",
    "file-type": "^22.0.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "imapflow": "^1.5.0",
    "ioredis": "^5.7.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.14",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.23.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.3",
    "otpauth": "^9.4.1",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^6.0.0",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^7.0.2",
    "uuid": "^14.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.16.1",
    "read-excel-file": "^9.3.2",
    "supertest": "^7.1.4",
    "ts-morph": "^28.0.0",
    "tsx": "^4.20.5",
    "typescript": "^7.0.2",
    "vitest": "^3.2.4"
  }
}
