NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_PUBLIC_URL=https://travel.example.com
DATABASE_URL=mysql://moon_user:change-me@mysql:3306/moonsconfig
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=moonsconfig
JWT_AUDIENCE=moonsconfig-client
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=14
AUTH_PASSWORD_PEPPER=replace-with-at-least-24-random-characters
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080
PUBLIC_SITE_ORIGIN=http://localhost:8080
CONFIG_PUBLIC_URL=http://localhost:8080
GOOGLE_CLIENT_ID=
TRUST_PROXY=1
RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT=500
OPERATION_RATE_LIMIT=3000
REALTIME_RATE_LIMIT=3000
COOKIE_SECURE=false
# Production mobile auth requires COOKIE_SECURE=true and CUSTOMER_COOKIE_SAME_SITE=none.
CUSTOMER_COOKIE_SAME_SITE=lax
SOCKET_IO_ENABLED=false
ARI_URL=http://127.0.0.1:8088
ARI_USERNAME=asterisk
ARI_PASSWORD=replace-with-your-ari-password
ARI_OUTBOUND_ENDPOINT=moon
ASTERISK_WSL_DISTRO=Ubuntu
UPLOAD_DIRECTORY=../uploads
SCREEN_EXPORT_SOURCE_ROOT=
MAX_UPLOAD_BYTES=10485760
LOG_LEVEL=info
LOG_DIRECTORY=storage/logs
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
DAILY_REPORT_CRON=0 6 * * *
CLEANUP_CRON=0 2 * * *
DATA_SYNC_CRON=0 */6 * * *
AUTONOMOUS_SUPPORT_CRON=*/15 * * * * *
MAYA_AUTOPILOT_CRON=0 */10 * * * *
MAYA_OPS_SWEEP_CRON=0 */15 * * * *
TRAVEL_AUTOMATION_CRON=*/30 * * * * *
MAYA_ENABLED=true
MAYA_EXTERNAL_WRITES_ENABLED=false
MAYA_TOOL_ALLOWLIST=
MAYA_BRAIN_MODEL=gemini-2.5-flash
AERODATABOX_API_KEY=
AERODATABOX_API_HOST=aerodatabox.p.rapidapi.com
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
TRAVEL_RULES_PROVIDER=disabled
TRAVEL_RULES_API_KEY=
INSURANCE_PROVIDER=
INSURANCE_API_KEY=
INVENTORY_PROVIDER=
INVENTORY_API_BASE_URL=
INVENTORY_API_KEY=
INVENTORY_TIMEOUT_MS=20000
CRON_ENABLED=true
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD=replace-with-a-strong-initial-password
ADMIN_NAME=System Administrator
LEGACY_SESSION_ENABLED=true
IMAP_USER=
IMAP_PASS=
GEMINI_API_KEY=
GEMINI_API_KEYS=
GOOGLE_ADS_DEVELOPER_TOKEN=
META_ACCESS_TOKEN=
